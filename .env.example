# ──────────────────────────────────────────────────────────────
# AuditChain — Environment Variables
# Copy this file to .env and fill in your real keys.
# ──────────────────────────────────────────────────────────────

# OpenAI — LLM backbone for the LangGraph agent
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Etherscan — on-chain contract & tx lookups  (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Alchemy — reliable JSON-RPC node provider   (https://alchemy.com/dashboard)
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY

# WeilChain by Weilliptic — immutable audit-trail logging
# Get your key at https://weilliptic.ai/get-started
WEILCHAIN_API_KEY=YOUR_WEILCHAIN_API_KEY

# WeilChain network (testnet | mainnet)
WEILCHAIN_NETWORK=testnet

# WeilChain JSON-RPC endpoint
WEILCHAIN_RPC_URL=https://rpc.testnet.weilliptic.ai

# WeilChain MCP Applet address — deploy first:  weil applet deploy
WEILCHAIN_APPLET_ID=0xYOUR_APPLET_ADDRESS_AFTER_DEPLOY

# Application environment (development | staging | production)
APP_ENV=development

# Logging verbosity (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO